# ---- Secrets (this file is committed as an EXAMPLE; copy to .env.local and fill in) ----
# .env.local is gitignored and must never be committed.

# Google Gemini API key — powers AI trial matching.
# Get a free key at https://aistudio.google.com (free tier: 1,500 requests/day).
GEMINI_API_KEY=your_key_here

# Optional: override the model. Default is gemini-2.5-flash-lite (fast, works on free tier).
# For deeper reasoning (slower), try: gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash-lite

# Auth.js session secret — used to sign/encrypt login sessions.
# Generate one with:  openssl rand -base64 33
AUTH_SECRET=generate_with_openssl_rand_base64_33
