# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files — secrets live in .env*.local (never committed).
# .env holds only the non-secret SQLite DATABASE_URL and IS committed for reproducibility.
.env*.local
.env.production

# SQLite database files (local data, not committed)
dev.db
dev.db-journal
prisma/*.db
prisma/*.db-journal

# vercel
.vercel

# typescript
*.tsbuildinfo

# Local Claude Code settings
.claude/settings.local.json

/src/generated/prisma

# Personal demo script (local only, do not publish)
DEMO_SCRIPT.md
